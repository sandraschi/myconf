{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Teleconference MCP",
    "version": "0.1.0",
    "identifier": "com.sandraschi.teleconference-mcp",
    "build": {
        "frontendDist": "../apps/web/out",
        "devUrl": "http://localhost:10886",
        "beforeBuildCommand": "pwsh -NoProfile -Command \"$env:TAURI_BUILD='1'; npm run build --workspace=web\""
    },
    "app": {
        "windows": [
            {
                "label": "main",
                "title": "Teleconference MCP",
                "width": 1280,
                "height": 860,
                "minWidth": 700,
                "minHeight": 500,
                "resizable": true
            }
        ],
        "security": {
            "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:10720 http://tauri.localhost https://tauri.localhost tauri://localhost ipc: http://ipc.localhost; img-src 'self' data: http://127.0.0.1:10720; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
        }
    },
    "bundle": {
        "active": true,
        "targets": ["nsis"],
        "icon": ["icons/icon.png", "icons/icon.ico"],
        "resources": [
            "resources/teleconference-mcp-backend.exe",
            "resources/.env.example",
            "../scripts/install-mcp-clients.ps1"
        ],
        "windows": {
            "webviewInstallMode": {
                "type": "skip"
            },
            "nsis": {
                "installMode": "currentUser",
                "installerHooks": "./windows/hooks.nsh"
            }
        }
    },
    "plugins": {}
}
